<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.matisu.trollserver</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Applications/TrollInstaller.app/trollserver</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>ThrottleInterval</key>
    <integer>5</integer>
    <key>StandardOutPath</key>
    <string>/tmp/trollserver.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/trollserver.log</string>
</dict>
</plist>

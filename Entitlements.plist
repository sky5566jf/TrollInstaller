<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>com.apple.security.network.server</key>
    <true/>
    <key>com.apple.security.network.client</key>
    <true/>
    <key>platform-application</key>
    <true/>
    <key>com.apple.private.security.no-container</key>
    <true/>
    <key>com.apple.springboard.opensensitiveurl</key>
    <true/>
    <key>com.apple.springboard.appcontrol</key>
    <true/>
    <key>com.apple.security.exception.mach-lookup.global-name</key>
    <array>
        <string>com.apple.springboard.services</string>
        <string>com.apple.frontboard.systemappservice</string>
        <string>com.apple.lsd.applicationdb</string>
    </array>
    <!-- NEHotspotHelper：纯巨魔版重启自启的核心 entitlement -->
    <!-- TrollStore 永久签名保留这些私有 entitlement，使 App 能注册 WiFi 关联事件回调 -->
    <!-- 设备重启 → 系统连 WiFi → HotspotHelper 触发 → 系统冷启动 App → 拉起 supervisor -->
    <key>com.apple.developer.networking.HotspotHelper</key>
    <true/>
    <key>com.apple.developer.networking.HotspotConfiguration</key>
    <true/>
</dict>
</plist>
